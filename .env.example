# =============================================================================
# Aura Intelligence Suite v7.5 — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# En producción, estos valores deben provenir de HashiCorp Vault.
# Ver .agent/AGENT.md §3.1 para los paths de Vault.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
SERVER_IP=your-server-ip-or-localhost
DOMAIN=localhost
TZ=America/Mexico_City

# -----------------------------------------------------------------------------
# POSTGRESML (OLTP — Base de datos transaccional)
# Vault path: secret/aura/postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=superset
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=superset

# -----------------------------------------------------------------------------
# CLICKHOUSE (OLAP — Motor analítico)
# Vault path: secret/aura/clickhouse
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=aura
CLICKHOUSE_PASSWORD=change_this_clickhouse_password

# -----------------------------------------------------------------------------
# VALKEY / REDIS (Cache y pre-agregaciones de Cube)
# DB 0 → Celery (Superset tasks)
# DB 1 → Cube.js pre-agregaciones (Rollups)
# -----------------------------------------------------------------------------
# No se necesita password en configuración básica.
# Para producción, agregar: --requirepass <password>

# -----------------------------------------------------------------------------
# CUBE.JS (Capa Semántica — SQL API)
# Vault path: secret/aura/cube
# -----------------------------------------------------------------------------
CUBE_SQL_USER=superset
CUBE_SQL_PASSWORD=change_this_cube_password

# -----------------------------------------------------------------------------
# SUPERSET (BI & Visualización)
# Vault path: secret/aura/superset
# Generar SECRET_KEY con: openssl rand -base64 42
# -----------------------------------------------------------------------------
SECRET_KEY=change_this_to_a_secure_random_string
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=change_this_secure_admin_password
ROW_LIMIT=5000000
SUPERSET_WEBSERVER_PORT=8088

# -----------------------------------------------------------------------------
# KEYCLOAK (OIDC Identity Provider)
# Vault path: secret/aura/keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_keycloak_password
OIDC_CLIENT_ID=superset
OIDC_OPENID_REALM=superset
OIDC_ISSUER_URL=http://host.docker.internal:8001/auth/realms/superset
OIDC_CLIENT_SECRET=change_this_oidc_secret

# -----------------------------------------------------------------------------
# SMTP (Alertas y Reportes de Superset)
# Vault path: secret/aura/smtp
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=change_this_smtp_password
MAIL_DEFAULT_RECIPIENT=admin@example.com

# -----------------------------------------------------------------------------
# GRAFANA (Observabilidad)
# Vault path: secret/aura/grafana
# -----------------------------------------------------------------------------
GF_ADMIN_PASSWORD=change_this_grafana_password

# -----------------------------------------------------------------------------
# IA — OpenAI (Vanna AI / Flowise)
# Vault path: secret/aura/openai
# Generar en: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# REPORTING (Superset Alert & Report Worker)
# -----------------------------------------------------------------------------
ALERT_REPORTS_WORKER_USERNAME=admin
WEBDRIVER_BASEURL=http://superset:8088

# -----------------------------------------------------------------------------
# PYPI MIRROR (Opcional — usar si pypi.org está bloqueado)
# -----------------------------------------------------------------------------
# PYPI_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple
PYPI_MIRROR=https://pypi.org/simple/

# -----------------------------------------------------------------------------
# HASHICORP VAULT (Producción)
# Descomentar cuando se migre de .env a Vault Agent Injector
# Ver .agent/AGENT.md §3.2 para instrucciones de integración
# -----------------------------------------------------------------------------
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=your_vault_token_here
# VAULT_NAMESPACE=aura
