# SMTP Configuration for Superset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASSWORD=your_password
MAIL_DEFAULT_RECIPIENT=admin@example.com

# Security
# Run `openssl rand -base64 42` to generate a key
SECRET_KEY=change_this_to_a_secure_random_string

# Postgres
POSTGRES_USER=superset
POSTGRES_PASSWORD=superset
POSTGRES_DB=superset

# Domain or IP for Nginx/Grafana
DOMAIN=localhost
SERVER_IP=your-server-ip-or-localhost

# AI Layer Configuration
# Generate a key from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Credentials for MCP/Vanna (can use the ones above if needed)
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=your_secure_password_here
